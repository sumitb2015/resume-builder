# Firebase configuration
# 1. Go to https://console.firebase.google.com → create/select your project
# 2. Project Settings → Your apps → Add a Web App
# 3. Copy the firebaseConfig values below
# 4. Authentication → Sign-in method → Enable Google
# 5. Copy this file to .env and fill in the values

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Backend API URL (leave empty for local dev, set for production)
# In Railway: set this to your server service's public URL
# e.g. VITE_API_URL=https://your-server.railway.app
VITE_API_URL=

# Razorpay Key ID
VITE_RAZORPAY_KEY_ID=your_razorpay_key_id
