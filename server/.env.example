# OpenAI API key — required for all AI features
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Razorpay Keys
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Discount codes: format CODE:PERCENTAGE, comma separated
# e.g. SUMMER20:20,WELCOME50:50
DISCOUNT_CODES=

# Port (Railway sets this automatically, leave unset for local dev)
# PORT=3001

# Frontend URL for CORS allowlist — required in production
# In Railway: set this to your client service's public URL
# e.g. FRONTEND_URL=https://your-client.railway.app
FRONTEND_URL=

# Puppeteer — set automatically by server/nixpacks.toml in Railway
# Only needed if you're running Chrome on a custom path locally
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
# Firecrawl API Key for web search capabilities
# Get one at https://www.firecrawl.dev/
FIRECRAWL_API_KEY=fc-...
