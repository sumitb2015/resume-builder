# OpenAI API key — required for all AI features
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Port (Railway sets this automatically, leave unset for local dev)
# PORT=3001

# Frontend URL for CORS allowlist — required in production
# In Railway: set this to your client service's public URL
# e.g. FRONTEND_URL=https://your-client.railway.app
FRONTEND_URL=

# Puppeteer — set automatically by server/nixpacks.toml in Railway
# Only needed if you're running Chrome on a custom path locally
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
# PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true
